generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String      @id
  email          String      @unique
  gebruikersnaam String?     @unique
  naam           String?
  aangemaaktOp   DateTime    @default(now())
  aantalWinsten  Int         @default(0)
  isAdmin        Boolean     @default(false)
  deelnemers     Deelnemer[]
}

model Poule {
  id                   String      @id @default(cuid())
  naam                 String
  code                 String      @unique
  soort                String      @default("wk")
  aangemaaktOp         DateTime    @default(now())
  organisatorId        String?
  topscorerActief                    Boolean  @default(false)
  geleKaartenActief                  Boolean  @default(false)
  toernooiwinaarActief               Boolean  @default(false)
  eersteDoelpuntenmakerActief        Boolean  @default(false)
  eersteDoelpuntenminuutActief       Boolean  @default(false)
  topscorerResultaat                 String?
  geleKaartenResultaat               String?
  toernooiwinaarResultaat            String?
  eersteDoelpuntenmakerResultaat     String?
  eersteDoelpuntenminuutResultaat    Int?
  afgerond                           Boolean  @default(false)
  winnaarId                          String?
  featured                           Boolean  @default(false)
  deelnemers           Deelnemer[]
}

model Deelnemer {
  id                      String         @id @default(cuid())
  userId                  String
  user                    User           @relation(fields: [userId], references: [id])
  pouleId                 String
  poule                   Poule          @relation(fields: [pouleId], references: [id])
  voorspellingen          Voorspelling[]
  topscorerVoorspelling                String?
  geleKaartenVoorspelling              String?
  toernooiwinaarVoorspelling           String?
  eersteDoelpuntenmakerVoorspelling    String?
  eersteDoelpuntenminuutVoorspelling   Int?
  lmsPicks                LmsPick[]
  lmsActief               Boolean        @default(true)
  lmsUitgeschakeldRonde   Int?
  betaald                 Boolean        @default(false)

  @@unique([userId, pouleId])
}

model LmsPick {
  id          String    @id @default(cuid())
  deelnemerId String
  deelnemer   Deelnemer @relation(fields: [deelnemerId], references: [id])
  rondeNr     Int
  teamCode    String
  wedstrijdId String
  uitkomst    String?

  @@unique([deelnemerId, rondeNr])
}

model Voorspelling {
  id          String    @id @default(cuid())
  wedstrijdId String
  thuis       Int?
  uit         Int?
  deelnemerId String
  deelnemer   Deelnemer @relation(fields: [deelnemerId], references: [id])

  @@unique([deelnemerId, wedstrijdId])
}

model Resultaat {
  wedstrijdId String @id
  thuis       Int
  uit         Int
}

model TournamentStat {
  type         String   @id
  waarde       String
  bijgewerktOp DateTime @updatedAt
}

model FeatureFlag {
  naam         String   @id
  aanGezet     Boolean  @default(false)
  beschrijving String   @default("")
  bijgewerktOp DateTime @updatedAt
}

model Speler {
  id      String @id @default(cuid())
  naam    String
  positie String
  team    String
  soort   String

  @@unique([naam, team, soort])
}
