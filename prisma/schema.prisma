generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String      @id
  email          String      @unique
  gebruikersnaam String?     @unique
  aangemaaktOp   DateTime    @default(now())
  deelnemers     Deelnemer[]
}

model Poule {
  id                   String      @id @default(cuid())
  naam                 String
  code                 String      @unique
  aangemaaktOp         DateTime    @default(now())
  organisatorId        String?
  topscorerActief                    Boolean  @default(false)
  geleKaartenActief                  Boolean  @default(false)
  toernooiwinaarActief               Boolean  @default(false)
  eersteDoelpuntenmakerActief        Boolean  @default(false)
  eersteDoelpuntenminuutActief       Boolean  @default(false)
  topscorerResultaat                 String?
  geleKaartenResultaat               String?
  toernooiwinaarResultaat            String?
  eersteDoelpuntenmakerResultaat     String?
  eersteDoelpuntenminuutResultaat    Int?
  deelnemers           Deelnemer[]
}

model Deelnemer {
  id                      String         @id @default(cuid())
  userId                  String
  user                    User           @relation(fields: [userId], references: [id])
  pouleId                 String
  poule                   Poule          @relation(fields: [pouleId], references: [id])
  voorspellingen          Voorspelling[]
  topscorerVoorspelling                String?
  geleKaartenVoorspelling              String?
  toernooiwinaarVoorspelling           String?
  eersteDoelpuntenmakerVoorspelling    String?
  eersteDoelpuntenminuutVoorspelling   Int?

  @@unique([userId, pouleId])
}

model Voorspelling {
  id          String    @id @default(cuid())
  wedstrijdId String
  thuis       Int?
  uit         Int?
  deelnemerId String
  deelnemer   Deelnemer @relation(fields: [deelnemerId], references: [id])

  @@unique([deelnemerId, wedstrijdId])
}

model Resultaat {
  wedstrijdId String @id
  thuis       Int
  uit         Int
}

model TournamentStat {
  type         String   @id
  waarde       String
  bijgewerktOp DateTime @updatedAt
}
