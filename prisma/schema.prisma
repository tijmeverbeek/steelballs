generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String      @id
  email          String      @unique
  gebruikersnaam String?     @unique
  aangemaaktOp   DateTime    @default(now())
  deelnemers     Deelnemer[]
}

model Poule {
  id                   String      @id @default(cuid())
  naam                 String
  code                 String      @unique
  aangemaaktOp         DateTime    @default(now())
  organisatorId        String?
  topscorerActief           Boolean     @default(false)
  geleKaartenActief         Boolean     @default(false)
  toernooiwinaarActief      Boolean     @default(false)
  topscorerResultaat        String?
  geleKaartenResultaat      String?
  toernooiwinaarResultaat   String?
  deelnemers           Deelnemer[]
}

model Deelnemer {
  id                      String         @id @default(cuid())
  userId                  String
  user                    User           @relation(fields: [userId], references: [id])
  pouleId                 String
  poule                   Poule          @relation(fields: [pouleId], references: [id])
  voorspellingen          Voorspelling[]
  topscorerVoorspelling      String?
  geleKaartenVoorspelling    String?
  toernooiwinaarVoorspelling String?

  @@unique([userId, pouleId])
}

model Voorspelling {
  id          String    @id @default(cuid())
  wedstrijdId String
  thuis       Int?
  uit         Int?
  deelnemerId String
  deelnemer   Deelnemer @relation(fields: [deelnemerId], references: [id])

  @@unique([deelnemerId, wedstrijdId])
}

model Resultaat {
  wedstrijdId String @id
  thuis       Int
  uit         Int
}
